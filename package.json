{
  "name": "esp32cam-proxy-server",
  "version": "1.0.0",
  "description": "Servidor proxy Node.js para ESP32-CAM que permite múltiples conexiones simultáneas al stream MJPEG sin saturar la cámara",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node --env-file=.env server.js",
    "dev": "node --env-file=.env --watch server.js",
    "build": "docker compose build",
    "docker-start": "docker compose up -d"
  },
  "keywords": [
    "esp32",
    "esp32-cam",
    "proxy",
    "mjpeg",
    "stream",
    "camera",
    "iot",
    "video-streaming"
  ],
  "author": "PedroPab",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  }
}